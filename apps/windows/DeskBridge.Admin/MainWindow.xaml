<Window x:Class="DeskBridge.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskBridge" Width="980" Height="820"
        MinWidth="900" MinHeight="720"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        UseLayoutRounding="True">
  <Window.Resources>
    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="PillBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="15"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>

    <Style x:Key="StatusBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="MinWidth" Value="116"/>
    </Style>

    <Style x:Key="MutedLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SubtleText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
        <Border Style="{StaticResource StatusBorder}" Margin="0,0,10,0">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="9"
                Padding="3">
          <UniformGrid Columns="2" Width="178">
            <RadioButton Content="Server"
                         GroupName="Mode"
                         IsChecked="{Binding IsServerMode, Mode=TwoWay}"
                         Style="{StaticResource SegmentRadioButton}"/>
            <RadioButton Content="Client"
                         GroupName="Mode"
                         IsChecked="{Binding IsClientMode, Mode=TwoWay}"
                         Style="{StaticResource SegmentRadioButton}"/>
          </UniformGrid>
        </Border>
      </StackPanel>

      <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <Border Width="32" Height="32" CornerRadius="8" Background="#22CDEA69" Margin="0,0,10,0">
            <TextBlock Text="DB" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
          </Border>
          <TextBlock Text="{Binding WindowTitle}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Border Style="{StaticResource PillBorder}" Margin="0,0,8,0">
            <TextBlock Text="{Binding Mode}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold"/>
          </Border>
          <Border Style="{StaticResource PillBorder}" Margin="0,0,8,0">
            <TextBlock Text="{Binding RouteSummary}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold"/>
          </Border>
          <Border Style="{StaticResource PillBorder}">
            <TextBlock Text="{Binding ClipboardSummary}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold"/>
          </Border>
        </StackPanel>
      </StackPanel>
    </DockPanel>

    <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal">
        <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
        <Button Content="{Binding StopButtonText}" Command="{Binding StopCommand}" Margin="0,0,10,0"/>
      </StackPanel>

      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Save Config" Command="{Binding SaveConfigCommand}" Margin="0,0,10,0" Visibility="{Binding ServerSettingsVisibility}"/>
        <Button Content="Run Diagnostics" Command="{Binding DiagnoseCommand}" Margin="0,0,10,0"/>
        <Button Content="Open Firewall" Command="{Binding FirewallCommand}" Visibility="{Binding ServerSettingsVisibility}"/>
      </StackPanel>
    </DockPanel>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,14">
          <StackPanel>
            <DockPanel LastChildFill="False" Margin="0,0,0,14">
              <TextBlock Text="Connection" FontSize="16" FontWeight="SemiBold"/>
              <TextBlock DockPanel.Dock="Right"
                         Text="{Binding PeerLayoutSummary}"
                         Style="{StaticResource SubtleText}"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"/>
            </DockPanel>

            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="128"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="128"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <TextBlock Text="Listen" Style="{StaticResource MutedLabel}" Visibility="{Binding ServerSettingsVisibility}"/>
              <TextBox Grid.Column="1" Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding ServerSettingsVisibility}"/>
              <TextBlock Text="Target" Style="{StaticResource MutedLabel}" Visibility="{Binding ClientSettingsVisibility}"/>
              <TextBox Grid.Column="1" Text="{Binding ClientServerAddress, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding ClientSettingsVisibility}"/>

              <TextBlock Grid.Column="3" Text="Config" Style="{StaticResource MutedLabel}"/>
              <TextBox Grid.Column="4" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}"/>

              <TextBlock Grid.Row="1" Text="{Binding LocalNameLabel}" Style="{StaticResource MutedLabel}" Margin="0,12,0,0"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,12,0,0" Visibility="{Binding ServerSettingsVisibility}"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding AllowedClient, UpdateSourceTrigger=PropertyChanged}" Margin="0,12,0,0" Visibility="{Binding ClientSettingsVisibility}"/>

              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PeerNameLabel}" Style="{StaticResource MutedLabel}" Margin="0,12,0,0"/>
              <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding AllowedClient, UpdateSourceTrigger=PropertyChanged}" Margin="0,12,0,0" Visibility="{Binding ServerSettingsVisibility}"/>
              <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,12,0,0" Visibility="{Binding ClientSettingsVisibility}"/>

              <TextBlock Grid.Row="2" Text="Clipboard" Style="{StaticResource MutedLabel}" Margin="0,12,0,0"/>
              <WrapPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,12,0,0">
                <CheckBox Content="Sync" IsChecked="{Binding ClipboardEnabled}" Margin="0,0,18,0"/>
                <CheckBox Content="Text" IsChecked="{Binding ClipboardText}" Margin="0,0,18,0"/>
                <CheckBox Content="Image" IsChecked="{Binding ClipboardImage}" Margin="0,0,18,0"/>
                <CheckBox Content="Files" IsChecked="{Binding ClipboardFiles}"/>
              </WrapPanel>

              <TextBlock Grid.Row="3" Text="Input" Style="{StaticResource MutedLabel}" Margin="0,12,0,0" Visibility="{Binding ServerSettingsVisibility}"/>
              <WrapPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,12,0,0" Visibility="{Binding ServerSettingsVisibility}">
                <CheckBox Content="Capture keyboard and mouse" IsChecked="{Binding CaptureInput}" Margin="0,0,18,0"/>
                <CheckBox Content="Reverse remote wheel" IsChecked="{Binding ReverseScroll}" Margin="0,0,18,0"/>
                <CheckBox Content="Keep route history" IsChecked="{Binding DebugLogging}"/>
              </WrapPanel>

              <TextBlock Grid.Row="4" Text="Route" Style="{StaticResource MutedLabel}" Margin="0,12,0,0" Visibility="{Binding ServerSettingsVisibility}"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"
                         Text="{Binding LayoutSummary}"
                         Foreground="{StaticResource MutedTextBrush}"
                         TextWrapping="Wrap"
                         Margin="0,12,0,0"
                         Visibility="{Binding ServerSettingsVisibility}"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,14" Visibility="{Binding LayoutVisibility}">
          <StackPanel>
            <DockPanel Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Display Layout" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LayoutSummary}" Style="{StaticResource SubtleText}" Margin="0,3,0,0"/>
              </StackPanel>
            </DockPanel>

            <Border Height="220" Width="820" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1" CornerRadius="8" ClipToBounds="True" HorizontalAlignment="Left">
              <Canvas x:Name="LayoutCanvas">
                <Border x:Name="LocalScreen"
                        Canvas.Left="{Binding LocalBoxLeft}" Canvas.Top="{Binding LocalBoxTop}"
                        Width="{Binding LocalBoxWidth}" Height="{Binding LocalBoxHeight}"
                        CornerRadius="7" BorderThickness="1" BorderBrush="{StaticResource LocalScreenBorderBrush}" Background="{StaticResource LocalScreenBrush}">
                  <StackPanel VerticalAlignment="Center" Margin="8">
                    <TextBlock Text="{Binding LocalDisplayName}" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding LocalDisplaySummary}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </Border>

                <Border x:Name="PeerScreen"
                        Canvas.Left="{Binding PeerBoxLeft}" Canvas.Top="{Binding PeerBoxTop}"
                        Width="{Binding PeerBoxWidth}" Height="{Binding PeerBoxHeight}"
                        CornerRadius="7" BorderThickness="1" BorderBrush="{StaticResource PeerScreenBorderBrush}" Background="{StaticResource PeerScreenBrush}"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="PeerScreen_MouseLeftButtonDown"
                        MouseMove="PeerScreen_MouseMove"
                        MouseLeftButtonUp="PeerScreen_MouseLeftButtonUp">
                  <StackPanel VerticalAlignment="Center" Margin="8">
                    <TextBlock Text="{Binding PeerDisplayName}" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding PeerDisplaySummary}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </Border>
              </Canvas>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource PanelBorder}">
          <Expander Foreground="{StaticResource TextBrush}" Background="Transparent" IsExpanded="False">
            <Expander.Header>
              <StackPanel Margin="4,0,0,0">
                <TextBlock Text="Diagnostics" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Available when you need logs, probes, and performance counters" Style="{StaticResource SubtleText}" Margin="0,3,0,0"/>
              </StackPanel>
            </Expander.Header>

            <TextBox Text="{Binding Diagnostics, Mode=OneWay}"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     MinHeight="160"
                     MaxHeight="240"
                     Margin="0,12,0,0"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
          </Expander>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
