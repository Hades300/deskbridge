<Window x:Class="DeskBridge.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskBridge" Width="920" Height="760"
        MinWidth="820" MinHeight="680"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
      <Ellipse Width="12" Height="12" Fill="{Binding StatusBrush}" Margin="0,0,12,0"/>
      <StackPanel>
        <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
      </StackPanel>
      <ComboBox DockPanel.Dock="Right" Width="150" SelectedValue="{Binding Mode}" SelectedValuePath="Content">
        <ComboBoxItem Content="Server"/>
        <ComboBoxItem Content="Client"/>
      </ComboBox>
    </DockPanel>

    <Grid Grid.Row="1" Margin="0,0,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <GroupBox Header="Local">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="104"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Text="Listen" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1" Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}"/>

          <TextBlock Grid.Row="1" Text="{Binding LocalNameLabel}" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>

          <TextBlock Grid.Row="2" Text="Config" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>

          <TextBlock Grid.Row="3" Text="Input" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <CheckBox Grid.Row="3" Grid.Column="1" Content="Capture keyboard and mouse when server" IsChecked="{Binding CaptureInput}" Margin="0,10,0,0"/>

          <TextBlock Grid.Row="4" Text="Scroll" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <CheckBox Grid.Row="4" Grid.Column="1" Content="Reverse wheel for remote input" IsChecked="{Binding ReverseScroll}" Margin="0,10,0,0"/>

          <TextBlock Grid.Row="5" Text="Debug" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <CheckBox Grid.Row="5" Grid.Column="1" Content="Keep capture route history" IsChecked="{Binding DebugLogging}" Margin="0,10,0,0"/>
        </Grid>
      </GroupBox>

      <GroupBox Grid.Column="2" Header="Peer">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="104"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Text="{Binding PeerNameLabel}" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1" Text="{Binding AllowedClient, UpdateSourceTrigger=PropertyChanged}"/>

          <TextBlock Grid.Row="1" Text="Client target" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ClientServerAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>

          <TextBlock Grid.Row="2" Text="Route" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RouteSummary}" Margin="0,10,0,0"
                     Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
        </Grid>
      </GroupBox>
    </Grid>

    <GroupBox Grid.Row="2" Header="Layout" Margin="0,0,0,18">
      <Grid Margin="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Drag the peer display around the local display. The green strips show the active crossing edges."
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,8"/>

        <Canvas x:Name="LayoutCanvas" Grid.Row="1" Height="190" Background="#12000000" ClipToBounds="False">
          <Rectangle Canvas.Left="{Binding LocalGlowLeft}" Canvas.Top="{Binding LocalGlowTop}"
                     Width="{Binding LocalGlowWidth}" Height="{Binding LocalGlowHeight}" Fill="#8AF59B">
            <Rectangle.Effect>
              <DropShadowEffect Color="#56FF7A" ShadowDepth="0" BlurRadius="18" Opacity="0.95"/>
            </Rectangle.Effect>
          </Rectangle>

          <Rectangle Canvas.Left="{Binding PeerGlowLeft}" Canvas.Top="{Binding PeerGlowTop}"
                     Width="{Binding PeerGlowWidth}" Height="{Binding PeerGlowHeight}" Fill="#8AF59B">
            <Rectangle.Effect>
              <DropShadowEffect Color="#56FF7A" ShadowDepth="0" BlurRadius="18" Opacity="0.95"/>
            </Rectangle.Effect>
          </Rectangle>

          <Border Canvas.Left="{Binding LocalBoxLeft}" Canvas.Top="{Binding LocalBoxTop}"
                  Width="{Binding LocalBoxWidth}" Height="{Binding LocalBoxHeight}"
                  CornerRadius="7" BorderThickness="1" BorderBrush="#668CCBFF" Background="#228CCBFF">
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding LocalDisplayName}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding LocalNameLabel}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <Border x:Name="PeerScreen"
                  Canvas.Left="{Binding PeerBoxLeft}" Canvas.Top="{Binding PeerBoxTop}"
                  Width="{Binding PeerBoxWidth}" Height="{Binding PeerBoxHeight}"
                  CornerRadius="7" BorderThickness="1" BorderBrush="#66B892FF" Background="#22B892FF"
                  Cursor="SizeAll"
                  MouseLeftButtonDown="PeerScreen_MouseLeftButtonDown"
                  MouseMove="PeerScreen_MouseMove"
                  MouseLeftButtonUp="PeerScreen_MouseLeftButtonUp">
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding PeerDisplayName}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding PeerNameLabel}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Canvas>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="3" Header="Diagnostics">
      <TextBox Text="{Binding Diagnostics, Mode=OneWay}" Margin="12"
               FontFamily="Consolas" IsReadOnly="True"
               TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    </GroupBox>

    <DockPanel Grid.Row="4" Margin="0,18,0,0" LastChildFill="False">
      <Button Content="{Binding StartButtonText}" Command="{Binding StartCommand}" Margin="0,0,10,0"/>
      <Button Content="{Binding StopButtonText}" Command="{Binding StopCommand}" Margin="0,0,10,0"/>
      <Button Content="Save Config" Command="{Binding SaveConfigCommand}" Margin="0,0,10,0"/>
      <Button Content="Run Diagnostics" Command="{Binding DiagnoseCommand}" Margin="0,0,10,0"/>
      <Button Content="Open Firewall" Command="{Binding FirewallCommand}"/>
    </DockPanel>
  </Grid>
</Window>
