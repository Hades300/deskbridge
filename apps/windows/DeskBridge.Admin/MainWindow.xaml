<Window x:Class="DeskBridge.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskBridge" Width="820" Height="640"
        MinWidth="720" MinHeight="560"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,20">
      <Ellipse Width="12" Height="12" Fill="{Binding StatusBrush}" Margin="0,0,12,0"/>
      <StackPanel>
        <TextBlock Text="DeskBridge Server" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
      </StackPanel>
    </DockPanel>

    <Grid Grid.Row="1" Margin="0,0,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <GroupBox Header="Server">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="Listen" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1" Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock Grid.Row="1" Text="Name" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
          <TextBlock Grid.Row="2" Text="Config" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0"/>
          <TextBlock Grid.Row="3" Text="Input" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <CheckBox Grid.Row="3" Grid.Column="1" Content="Capture keyboard and mouse" IsChecked="{Binding CaptureInput}" Margin="0,10,0,0"/>
        </Grid>
      </GroupBox>

      <GroupBox Grid.Column="2" Header="Client">
        <Grid Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="Allowed" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1" Text="{Binding AllowedClient, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock Grid.Row="1" Text="Position" VerticalAlignment="Center" Margin="0,10,0,0"/>
          <ComboBox Grid.Row="1" Grid.Column="1" SelectedValue="{Binding ClientPosition}" SelectedValuePath="Content" Margin="0,10,0,0">
            <ComboBoxItem Content="Left"/>
            <ComboBoxItem Content="Right"/>
            <ComboBoxItem Content="Above"/>
            <ComboBoxItem Content="Below"/>
          </ComboBox>
        </Grid>
      </GroupBox>
    </Grid>

    <GroupBox Grid.Row="2" Header="Layout" Margin="0,0,0,18">
      <Grid Margin="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Padding="16" CornerRadius="6" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="{Binding ServerName}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="keyboard + mouse host" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
        <TextBlock Grid.Column="1" Text="{Binding LayoutArrow}" FontSize="24" Margin="16,0" VerticalAlignment="Center"/>
        <Border Grid.Column="2" Padding="16" CornerRadius="6" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="{Binding AllowedClient}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding ClientPosition}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="3" Header="Diagnostics">
      <TextBox Text="{Binding Diagnostics, Mode=OneWay}" Margin="12"
               FontFamily="Consolas" IsReadOnly="True"
               TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    </GroupBox>

    <DockPanel Grid.Row="4" Margin="0,18,0,0" LastChildFill="False">
      <Button Content="Start Server" Command="{Binding StartCommand}" Margin="0,0,10,0"/>
      <Button Content="Stop" Command="{Binding StopCommand}" Margin="0,0,10,0"/>
      <Button Content="Save Config" Command="{Binding SaveConfigCommand}" Margin="0,0,10,0"/>
      <Button Content="Run Diagnostics" Command="{Binding DiagnoseCommand}" Margin="0,0,10,0"/>
      <Button Content="Open Firewall" Command="{Binding FirewallCommand}"/>
    </DockPanel>
  </Grid>
</Window>
