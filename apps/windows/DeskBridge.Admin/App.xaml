<Application x:Class="DeskBridge.Admin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="WindowBrush" Color="#111113"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1A1A1D"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#222227"/>
    <SolidColorBrush x:Key="CanvasBrush" Color="#141416"/>
    <SolidColorBrush x:Key="InputBrush" Color="#121214"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#34343A"/>
    <SolidColorBrush x:Key="BorderBrushStrong" Color="#484850"/>
    <SolidColorBrush x:Key="TextBrush" Color="#F2F0E8"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#A5A197"/>
    <SolidColorBrush x:Key="SubtleTextBrush" Color="#77736B"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#CDEA69"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#6F833A"/>
    <SolidColorBrush x:Key="LocalScreenBrush" Color="#335B7DD6"/>
    <SolidColorBrush x:Key="LocalScreenBorderBrush" Color="#8CA9D7FF"/>
    <SolidColorBrush x:Key="PeerScreenBrush" Color="#335FA7A0"/>
    <SolidColorBrush x:Key="PeerScreenBorderBrush" Color="#8CCDB7A9"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Padding" Value="13,7"/>
      <Setter Property="MinWidth" Value="96"/>
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#2B2B31"/>
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#202024"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Padding" Value="13,7"/>
      <Setter Property="MinWidth" Value="96"/>
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Foreground" Value="#10120C"/>
      <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#DAF47B"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#B7D251"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Background" Value="{StaticResource InputBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="SelectionBrush" Value="{StaticResource AccentDimBrush}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
              </Trigger>
              <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="Background" Value="#151517"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </Application.Resources>
</Application>
