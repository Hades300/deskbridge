{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskBridge",
  "version": "0.1.0",
  "identifier": "fun.bytedance.deskbridge",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DeskBridge",
        "width": 920,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
